# Application
APP_NAME=Code Analytics Platform
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# MongoDB
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DATABASE=code_analytics
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=50

# Queue
QUEUE_NAME=scan_jobs
QUEUE_RESULT_TTL=3600
QUEUE_TIMEOUT=300

# Worker
WORKER_CONCURRENCY=10
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY=5
WORKER_POOL_SIZE=4

# Scanning
SCAN_TIMEOUT=3600
SCAN_MAX_FILE_SIZE=10485760
SCAN_CHUNK_SIZE=100
SCAN_CONCURRENCY_LIMIT=50

# Cache
CACHE_TTL=3600
CACHE_ENABLED=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=200

# Security
AUTH_ENABLED=true
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=code-analytics-platform
ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_TTL=3600
AUTH_TOKEN_COOKIE_NAME=cap_access_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
MAX_REPO_SIZE=10737418240

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
GITHUB_OAUTH_TIMEOUT_SECONDS=10

# Observability
ENABLE_METRICS=true
ENABLE_TRACING=true
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["*"]
