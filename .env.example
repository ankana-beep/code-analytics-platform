# Application
APP_NAME=Code Analytics Platform
APP_VERSION=1.0.0
DEBUG=false
DOCS_ENABLED=false
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# MongoDB
# Use your MongoDB Atlas connection string here.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DATABASE=code_analytics
MONGODB_MAX_POOL_SIZE=100
MONGODB_MIN_POOL_SIZE=10

# Redis is used only for AI summary caching and AI summary rate limiting.
REDIS_URL=redis://redis:6379/0

# Scanning
SCAN_TIMEOUT=3600
SCAN_MAX_FILE_SIZE=10485760
SCAN_CHUNK_SIZE=100
SCAN_CONCURRENCY_LIMIT=50

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=200

# Security
AUTH_ENABLED=true
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ISSUER=code-analytics-platform
ACCESS_TOKEN_EXPIRE_MINUTES=60
SESSION_TTL=3600
AUTH_TOKEN_COOKIE_NAME=cap_access_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
MAX_REPO_SIZE=10737418240
DOCS_USERNAME=docs_admin
DOCS_PASSWORD=change-me

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
GITHUB_OAUTH_TIMEOUT_SECONDS=10

# OpenAI AI Summary
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_SUMMARY_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=20
AI_SUMMARY_CACHE_TTL_SECONDS=86400
AI_SUMMARY_RATE_LIMIT_REQUESTS=2
AI_SUMMARY_RATE_LIMIT_WINDOW_SECONDS=60

# Observability
ENABLE_METRICS=true
ENABLE_TRACING=true
LOG_LEVEL=INFO

# CORS
CORS_ORIGINS=["*"]
